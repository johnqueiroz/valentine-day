# Produção — copie para .env na VM e ajuste o domínio.
# Gere a APP_KEY na VM: php artisan key:generate

APP_NAME="Wrapped do Casal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://SEU-SUBDOMINIO.duckdns.org

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=error

# Banco: SQLite em arquivo (persistente no disco da VM). Caminho ABSOLUTO.
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/valentine-day/database/database.sqlite
# (DB_HOST/PORT/USERNAME/PASSWORD não usados em sqlite)

# Sem worker/redis: tudo no banco/arquivo, fila síncrona.
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=local

# E-mail: log por padrão (admin não envia e-mails no fluxo atual).
MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

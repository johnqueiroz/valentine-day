# Caddy serve o Laravel com HTTPS automático (Let's Encrypt).
# Troque o domínio. Copie para /etc/caddy/Caddyfile e: systemctl reload caddy
#
# Requisitos: php8.3-fpm rodando no socket abaixo; app em /var/www/valentine-day.

SEU-SUBDOMINIO.duckdns.org {
	root * /var/www/valentine-day/public
	encode zstd gzip

	php_fastcgi unix//run/php/php8.3-fpm.sock
	file_server

	# Bloqueia acesso a dotfiles e ao .env.
	@hidden path /.*
	respond @hidden 404

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	log {
		output file /var/log/caddy/valentine-day.log
	}
}
